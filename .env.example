# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EMAIL_VERIFICATION_API_KEY: Required for email verification API calls (Abstract API).
# Get your free key from https://www.abstractapi.com/email-verification-api
EMAIL_VERIFICATION_API_KEY=

# VERIFALIA_APP_SID and VERIFALIA_APP_KEY: Required for Verifalia email verification.
# Get your credentials from https://verifalia.com/
VERIFALIA_APP_SID=
VERIFALIA_APP_KEY=

# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET: Required for Gmail API integration.
# Get your credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
